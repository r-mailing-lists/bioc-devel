===================================================================
--- R/SummarizedExperiment-class.R	(revision 94987)
+++ R/SummarizedExperiment-class.R	(working copy)
@@ -635,7 +635,7 @@
x <- lapply(x, unlist) 
x1 <- x[[1]]
}
- for (i in seq_along(x[-1])) {
+ for (i in seq_along(x)[-1]) {
if (length(x1) != length(x[[i]]))
return(FALSE)
ok <- x1 == x[[i]]

