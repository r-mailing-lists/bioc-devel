> samplefile <- system.file('extdata', 'UCSC_knownGene_sample.sqlite',
+       package='GenomicFeatures')
> old <- loadDb(samplefile)
> new <- loadDb(samplefile, dbType = 'TxDb', dbPackage = 'GenomicFeatures')

