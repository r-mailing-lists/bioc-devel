+   function(new=NULL, name="TEXINPUTS")
+ {
+     current <- Sys.getenv(name)
+     if (length(new) > 0L) {
+         new <- normalizePath(new)
+         args <- list(unique_path(c(new, current)))
+         names(args) <-name
+         do.call(Sys.setenv, args)
+         current <- Sys.getenv(name)
+     }
