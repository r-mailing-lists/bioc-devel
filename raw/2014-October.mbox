gr = GRanges(seqnames = "chr11",
     ranges = IRanges(start = c(58109576, 58111391), width = c(1,1)))
puparam = PileupParam(minBaseQuality = 20L, what = "seq", which = gr)
pu = applyPileups(files = pf, FUN = pileupfxn, param = puparam)

