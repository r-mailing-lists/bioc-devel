>>> former. So if we define an as.vector S3 method for A objects:
>>>
>>>   setClass("A", representation(stuff="numeric"))
>>>   as.vector.A <- function (x, mode="any") x at stuff
>>>   a <- new("A", stuff=c(3.5, 0.1))
>>>   x <- numeric(10)
>>>   x[3:4] <- a
