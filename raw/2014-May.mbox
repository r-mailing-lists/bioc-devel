>> {
>> reads <- as(reads, "GRanges")
>> if (any(strand(reads) == "*"))
>> stop("all reads must have strand")
>> if (!is.null(width))
>> reads <- do.call(resize(reads, width, fix=fix,
>> use.names=use.names,
>> ignore.strand=ignore.strand))
>>
