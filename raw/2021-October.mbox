replace_unstranded <- function (gr) {
     idx <- strand(gr) == "*"
     if (length(idx) == 0L)
         return(gr)
     sort(c(
         gr[! idx],
         `strand<-`(gr[idx], value = "+"),
         `strand<-`(gr[idx], value = "-")))
}


