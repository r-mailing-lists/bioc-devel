approach3 <- function(ranges, files) {
    bwViews <- BigWigFileViews(fileRange = ranges, fileList = files)
    cov <- coverage(bwViews)
    vec <- sapply(assay(cov), function(xx) mean(xx[[1]]))
    out <- matrix(vec, ncol = length(files), nrow = length(ranges))
    out
}

