 ? var01 <- foo
 ? ...
 ? varXX <- bar
 ? data_list <- list(data01, data02, data03, ... , dataYY)

 ? lapply(
 ??? seq_along(data_list),
 ??? function(
 ????? i,
 ????? var01,
 ????? ...
 ????? varXX
 ??? ) {
 ????? stuff
 ????? helper_function(var01, ... , varXX)
 ??? },
 ??? var01 = var01,
 ??? ...
 ??? varXX = varXX
 ? )
}


Thank you very much!

Best,
Severin


