	}

	public org.bioconductor.packages.rservices.RMatrix webVsn(
        org.bioconductor.packages.rservices.RMatrix expressionMatrix,
        org.bioconductor.packages.webVSN.JustVSNParameter
        justVSNParameter)
      throws java.rmi.RemoteException {
