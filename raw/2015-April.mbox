I used my unreleased rgtags package to search for references to setOldClass
in Bioc:

library(rgtags)
classes <- sub(".*\\.", "", methods(print))
defs <- do.call(c, lapply(classes, findDefinitions))
oldClass <- lapply(expr(defs), `[[`, 1L) == quote(setOldClass)
defs[oldClass]

