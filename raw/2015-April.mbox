What about appending the strand only for GRanges objects that
have at least one range that is not on *?

setMethod("as.character", "GenomicRanges",
     function(x)
     {
         if (length(x) == 0L)
             return(character(0))
         ans <- paste0(seqnames(x), ":", start(x), "-", end(x))
         if (any(strand(x) != "*"))
               ans <- paste0(ans, ":", strand(x))
         ans
     }
)

