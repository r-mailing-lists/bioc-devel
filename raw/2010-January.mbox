> INTEGER(N)[0], i2, j2, q, INTEGER(nTests)[0],REAL(alpha)[0]);
>
> ? ?REAL(nrrMatrix)[j2+i2*n_var] = REAL(nrrMatrix)[i2+j2*n_var];
> ? ?k++;
> ? ?pct = (int) ((k * 100) / n_adj);
> ? ?if (pct != ppct) {
> ? ? ?if (INTEGER(verbose)[0]) { ## show progress when
