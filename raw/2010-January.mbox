> ? ? ? ? ?Rprintf("%d",pct);
> ? ? ? ?else
> ? ? ? ? ?Rprintf(".",pct);
> ? ? ? ?R_FlushConsole();
> ? ? ?}
> ? ? ?R_CheckUserInterrupt();
> #ifdef Win32
> ? ? ?R_ProcessEvents();
> #endif
> #ifdef HAVE_AQUA
> ? ? ?R_ProcessEvents();
> #endif
> ? ? ?ppct = pct;
