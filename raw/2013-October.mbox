>
> # 0 length list returned
> bam <- scanBam(sampleFile,param=param)[[1]]
> summary(bam)
>
> # specify anything for what and it works as expected #2397 records imported
> param <- ScanBamParam(flag=flag,which=which, what=scanBamWhat())
> bam <- scanBam(sampleFile,param=param)[[1]]
> summary(bam)
