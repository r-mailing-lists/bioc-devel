## metadata(0):
## assays(1): ''
## rownames(10): g1 g2 ... g9 g10
## rowData names(0):
## colnames(30): s1 s2 ... s29 s30
## colData names(0):
## reducedDimNames(0):
## mainExpName: NULL
## altExpNames(0):

expShow(sce)
## Error: unable to find an inherited method for function 'expShow'
for signature 'object = "SingleCellExperiment"'

