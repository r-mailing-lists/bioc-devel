>       eh <- try(.get_eh(), silent=TRUE)
>       if (inherits(eh, "try-error")) {
>         eh <- ExperimentHub()
>         .set_eh(eh)
>       }
>       eh
>     }
>
> Hope this helps,
>
> H.
